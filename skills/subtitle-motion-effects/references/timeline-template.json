{
  "canvas": {
    "width": 1080,
    "height": 1920,
    "fps": 30,
    "duration": 5,
    "base_fit": "cover",
    "background_color": "#000000"
  },
  "fonts": [
    {
      "family": "FZLanTing",
      "path": "assets/fonts/FZLanTingHei-Medium.ttf"
    },
    {
      "family": "SodaFont",
      "path": "assets/fonts/SodaFont-Regular.otf"
    }
  ],
  "branding": {
    "words": ["汽水音乐", "汽水"],
    "style": {
      "fontFamily": "SodaFont",
      "fontSize": 76,
      "fontWeight": 900,
      "color": "#3BFD42",
      "strokeColor": "#071307",
      "strokeWidth": 4,
      "shadowBlur": 0
    },
    "scale": 1.15
  },
  "defaultStyle": {
    "fontFamily": "FZLanTing",
    "fontSize": 64,
    "fontWeight": 800,
    "color": "#FFFFFF",
    "strokeColor": "#101010",
    "strokeWidth": 3,
    "shadowBlur": 0,
    "lineHeight": 1.12,
    "letterSpacing": 0
  },
  "defaultStylePreset": "standard_white",
  "defaultEffectPreset": "pop_bold",
  "defaultEffect": {
    "type": "drop_word",
    "preset": "soft_drop",
    "granularity": "char",
    "duration": 0.52,
    "stagger": 0.032
  },
  "subtitles": [
    {
      "id": "s1",
      "start": 0,
      "end": 2.3,
      "text": "每天听汽水音乐15分钟",
      "position": "lower_center",
      "maxWidth": 930,
      "stylePreset": "standard_white",
      "effectPreset": "drop_in",
      "tokens": [
        {"word": "每", "start_time": 0, "end_time": 150},
        {"word": "天", "start_time": 150, "end_time": 300},
        {"word": "听", "start_time": 300, "end_time": 450},
        {"word": "汽", "start_time": 450, "end_time": 600},
        {"word": "水", "start_time": 600, "end_time": 750},
        {"word": "音", "start_time": 750, "end_time": 900},
        {"word": "乐", "start_time": 900, "end_time": 1050},
        {"word": "1", "start_time": 1050, "end_time": 1200},
        {"word": "5", "start_time": 1200, "end_time": 1350},
        {"word": "分", "start_time": 1350, "end_time": 1650},
        {"word": "钟", "start_time": 1650, "end_time": 2000}
      ],
      "effect": {
        "type": "pop_word"
      }
    },
    {
      "id": "s2",
      "start": 2.3,
      "end": 5,
      "text": "你的余额就会一直涨",
      "position": "lower_center",
      "maxWidth": 930,
      "stylePreset": "variety_yellow",
      "effectPreset": "heart_jump",
      "effect": {
        "type": "bounce_badge"
      }
    }
  ]
}
